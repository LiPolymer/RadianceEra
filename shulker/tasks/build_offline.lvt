import shulker.modrinth
# Build Windows version (offline)
var variantMeta mrpack_windows.template.json
var variantMods mods-windows
var variantName Windows
run _buildVariantOffline.lvt
# Build Linux version (offline)
var variantMeta mrpack_linux.template.json
var variantMods mods-linux
var variantName Linux
run _buildVariantOffline.lvt